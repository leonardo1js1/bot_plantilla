# Servidor
PORT=3000
BASE_URL=http://localhost:3000

# Negocio activo: crea src/config/business/<slug>.json y cambia este valor
BUSINESS_SLUG=aviator

# IA (Groq con SDK compatible con OpenAI)
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant
GROQ_REQUEST_TIMEOUT_MS=15000
GROQ_API_BASE_URL=https://api.groq.com/openai/v1

# Proveedor local de simulacion
WHATSAPP_PROVIDER=simulator

# Twilio (placeholders, opcion futura)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_NUMBER=

# UltraMsg (requerido solo si usaras /webhook-ultramsg)
ULTRAMSG_INSTANCE_ID=
ULTRAMSG_TOKEN=
ULTRAMSG_API_BASE_URL=https://api.ultramsg.com

# Meta Cloud API (requerido solo para verificar ese webhook)
WHATSAPP_VERIFY_TOKEN=aviator-demo-token
